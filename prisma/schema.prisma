generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum Category {
  ALGORITHMS
  ML_THEORY
  ML_PLATFORM
  SYSTEM_DESIGN
  JOB_APPLICATIONS
  READING
  MOCK_INTERVIEW
}

model User {
  id        String        @id @default(cuid())
  email     String?       @unique
  createdAt DateTime      @default(now())
  sessions  WorkSession[]
}

model WorkSession {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])

  category    Category
  status      SessionStatus @default(ACTIVE)

  startedAt   DateTime      @default(now())
  endedAt     DateTime?

  // Mandatory on clock-out (enforced in API)
  workedOn    String?
  output      String?
  difficulty  Int?
  focus       Int?

  // Optional anti-cheat
  minMinutes  Int           @default(25)

  segments    WorkSegment[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, startedAt])
  @@index([status])
}

model WorkSegment {
  id         String      @id @default(cuid())
  sessionId  String
  session    WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  startTime  DateTime    @default(now())
  endTime    DateTime?

  createdAt  DateTime    @default(now())

  @@index([sessionId, startTime])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  tags        String[] // Postgres array
  createdAt   DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String   // markdown
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyReport {
  id         String   @id @default(cuid())
  weekStart  String   @unique  // "YYYY-MM-DD" Monday of the week
  weekNumber Int?
  notes      Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}