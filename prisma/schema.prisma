generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

model TrackerCategory {
  id            String   @id @default(cuid())
  key           String   @unique  // e.g. "ALGORITHMS"
  label         String            // e.g. "Algorithms"
  targetMinutes Int      @default(0)
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id        String        @id @default(cuid())
  email     String?       @unique
  createdAt DateTime      @default(now())
  sessions  WorkSession[]
}

model WorkSession {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])

  category    String
  status      SessionStatus @default(ACTIVE)

  startedAt   DateTime      @default(now())
  endedAt     DateTime?

  // Mandatory on clock-out (enforced in API)
  workedOn    String?
  output      String?
  difficulty  Int?
  focus       Int?

  // Optional anti-cheat
  minMinutes  Int           @default(25)

  segments    WorkSegment[]
  notes       SessionNote[]
  durationEdits SessionDurationEdit[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, startedAt])
  @@index([status])
}

model WorkSegment {
  id         String      @id @default(cuid())
  sessionId  String
  session    WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  startTime  DateTime    @default(now())
  endTime    DateTime?

  createdAt  DateTime    @default(now())

  @@index([sessionId, startTime])
}

model SessionNote {
  id        String      @id @default(cuid())
  sessionId String
  session   WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content   String
  url       String?
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model SessionDurationEdit {
  id              String      @id @default(cuid())
  sessionId       String
  session         WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  previousMinutes Int
  newMinutes      Int
  createdAt       DateTime    @default(now())

  @@index([sessionId])
}

model Reminder {
  id        String   @id @default(cuid())
  type      String   @default("REMINDER") // "REMINDER" | "EXAM"
  title     String
  notes     String?
  subject   String?
  url       String?
  deadline  DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  excerpt     String   @default("")
  content     String   @default("")
  tags        String[]
  img         String   @default("")
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  tags      String[]
  img       String   @default("")
  published Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyReport {
  id         String   @id @default(cuid())
  weekStart  String   @unique  // "YYYY-MM-DD" Monday of the week
  weekNumber Int?
  notes      Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NotesSeries {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  tagline     String      @default("")
  description String      @default("")
  tags        String[]
  published   Boolean     @default(false)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  parts       NotesPart[]
}

model NotesPart {
  id         String      @id @default(cuid())
  slug       String
  seriesId   String
  series     NotesSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  title      String
  content    String      @default("")
  partNumber Int
  published  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([seriesId, slug])
  @@index([seriesId, partNumber])
}

model ResourceCategory {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ResourceType {
  INSTAGRAM
  YOUTUBE
  ARTICLE
  LEETCODE
  OTHER
}

model ResourceNote {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([resourceId])
}

model ResourceTask {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  title      String
  notes      String?
  completed  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([resourceId])
}

model Resource {
  id          String         @id @default(cuid())
  title       String
  url         String?
  description String?
  category    String         // e.g. "ALGORITHMS", "INTERVIEWS", "SYSTEM_DESIGN"
  type        ResourceType   @default(OTHER)
  completed   Boolean        @default(false)
  tags        String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tasks       ResourceTask[]
  notes       ResourceNote[]

  @@index([category])
  @@index([completed])
  @@index([type])
}