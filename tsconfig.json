{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "moduleResolution": "node",
    "noImplicitAny": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "prisma", "prisma.config.ts"]
}
